    <item>
      <title>338.Counting Bits</title>
      <link>http://changcui.cc/posts/leetcode-338/</link>
      <pubDate>Tue, 10 Dec 2019 00:39:28 +0800</pubDate>
      
      <guid>http://changcui.cc/posts/leetcode-338/</guid>
      <description>class Solution { public: vector&amp;lt;int&amp;gt; countBits(int num) { vector&amp;lt;int&amp;gt; res(num+1, 0); for (int i = 1; i &amp;lt;= num; i++) { res[i] = res[i &amp;amp; (i-1)] + 1; } return res; } }; </description>
